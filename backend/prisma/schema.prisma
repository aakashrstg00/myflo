generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String   @id @default(uuid()) @db.Uuid
  email               String   @unique
  created_at          DateTime @default(now())
  timezone_preference String?  @default("IST")
  is_active           Boolean  @default(true)
  is_partner          Boolean  @default(false)

  // Relations
  periodLogs  PeriodLog[]
  symptomLogs SymptomLog[]
  predictions Prediction[]

  // Partner Relations
  partnerLinksAsPrimary PartnerLink[] @relation("PrimaryUser")
  partnerLinksAsPartner PartnerLink[] @relation("PartnerUser")
}

enum FlowIntensity {
  Light
  Medium
  Heavy
  Spotting
}

model PeriodLog {
  id             String        @id @default(uuid()) @db.Uuid
  user_id        String        @db.Uuid
  date           DateTime      @db.Date
  flow_intensity FlowIntensity

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

enum SymptomType {
  cramps
  mood
  sleep
  energy
  pain
  bloating
}

model SymptomLog {
  id           String      @id @default(uuid()) @db.Uuid
  user_id      String      @db.Uuid
  date         DateTime    @db.Date
  symptom_type SymptomType
  severity     Int? // 1-3

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model Prediction {
  id                          String   @id @default(uuid()) @db.Uuid
  user_id                     String   @db.Uuid
  predicted_next_period_start DateTime @db.Date
  predicted_next_period_end   DateTime @db.Date
  confidence_interval_days    Int

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model PartnerLink {
  id               String   @id @default(uuid()) @db.Uuid
  created_at       DateTime @default(now())
  primary_user_id  String   @db.Uuid
  partner_user_id  String   @db.Uuid
  permissions_flag Json // e.g. ["period", "symptoms"]
  is_active        Boolean  @default(true)

  primary_user User @relation("PrimaryUser", fields: [primary_user_id], references: [id], onDelete: Cascade)
  partner_user User @relation("PartnerUser", fields: [partner_user_id], references: [id], onDelete: Cascade)

  @@index([primary_user_id])
  @@index([partner_user_id])
}
